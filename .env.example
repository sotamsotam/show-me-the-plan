# ── App (Caddy + Next.js) ──────────────────────────────────────
# Local Docker test: http://localhost (Caddy :80)
# Production HTTPS: https://your-domain.example.com
APP_DOMAIN=localhost
NEXTAUTH_URL=http://localhost
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Comma-separated browser origins allowed by Strapi CORS
CORS_ORIGIN=http://localhost,http://localhost:3000

# ── Strapi secrets ─────────────────────────────────────────────
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=change-me-strong-password

# ── External APIs ──────────────────────────────────────────────
NEIS_KEY=your-neis-api-key-here

# NEIS timetable in-memory cache (Strapi)
NEIS_CACHE_ENABLED=true
NEIS_CACHE_TTL_HOURS=12
NEIS_CACHE_MAX_ENTRIES=2000

# Email (Brevo SMTP) — Strapi password reset
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
BREVO_SMTP_USER=your-id@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-your-smtp-key
EMAIL_DEFAULT_FROM=your-verified-sender@example.com
EMAIL_DEFAULT_NAME=Show Me The Plan
FRONTEND_URL=http://localhost

# ── Billing (PortOne V2) ─────────────────────────────────────────
# Same secret on Strapi + Next.js BFF
BILLING_INTERNAL_SECRET=change-me-billing-internal-secret
BILLING_ENCRYPTION_KEY=change-me-32-characters-min-secret!!
BILLING_CRON_SECRET=change-me-cron-secret
# PortOne console: https://admin.portone.io
PORTONE_API_SECRET=portone_api_secret_replace_me
NEXT_PUBLIC_PORTONE_STORE_ID=store-id-replace-me
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-replace-me
# Local/dev: true | Production: MUST be false
PORTONE_WEBHOOK_SKIP_VERIFY=true
PORTONE_WEBHOOK_SECRET=portone_webhook_secret_replace_me

# Production go-live: see docs/BILLING-PRODUCTION-GO-LIVE.md
# Ops internal API (Strapi + Next.js BFF — x-ops-internal-secret)
OPS_INTERNAL_SECRET=change-me-ops-internal-secret

# ── Web Push (study-plan todo alarms) ───────────────────────────
# Generate: cd backend && npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@example.com

# ── Upload storage (Strapi Media Library) ───────────────────────
# local = Docker volume public/uploads (default)
# s3    = AWS S3 or S3-compatible (Cloudflare R2, MinIO, etc.)
UPLOAD_PROVIDER=local

# Required when UPLOAD_PROVIDER=s3
# UPLOAD_S3_ACCESS_KEY_ID=
# UPLOAD_S3_SECRET_ACCESS_KEY=
# UPLOAD_S3_BUCKET=
# UPLOAD_S3_REGION=auto
# UPLOAD_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# UPLOAD_S3_BASE_URL=https://cdn.example.com
# UPLOAD_S3_ROOT_PATH=
# UPLOAD_S3_ACL=
# UPLOAD_S3_FORCE_PATH_STYLE=false

# Browser image base URL (frontend)
# local Docker: same as NEXTAUTH_URL (Caddy proxies /uploads → Strapi)
# NEXT_PUBLIC_STRAPI_URL=http://localhost
# R2/CDN: set public asset URL (overrides STRAPI URL for relative upload paths)
# NEXT_PUBLIC_UPLOAD_BASE_URL=https://cdn.example.com
