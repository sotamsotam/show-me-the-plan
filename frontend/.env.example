# Cloudflare Turnstile (login / signup / forgot-password)
# ⚠️ 로컬 npm run dev: 아래 테스트 키 쌍을 사용하세요 (프로덕션 키는 localhost에서 동작 안 함)
# 프로덕션 키는 루트 .env + GitHub Variables + Cloudflare 위젯 hostname(showmepl.com)에만 둡니다.
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# TURNSTILE_ENABLED=false

# PortOne V2 (test keys from PortOne console)
# PORTONE_API_SECRET=portone_api_secret_...
# NEXT_PUBLIC_PORTONE_STORE_ID=store-...
# NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-...
# BILLING_INTERNAL_SECRET=same-as-root-env
# BILLING_CRON_SECRET=your-cron-secret
# OPS_INTERNAL_SECRET=same-as-root-env
# PORTONE_WEBHOOK_SKIP_VERIFY=true   # production: false
# PORTONE_WEBHOOK_SECRET=portone_webhook_secret_...
#
# Ops (from repo root):
# npm run billing:health
# npm run billing:cron
