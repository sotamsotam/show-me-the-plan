# Copy on VPS: cp scripts/backup-r2.env.example /root/.backup-r2.env
# Then: nano /root/.backup-r2.env && chmod 600 /root/.backup-r2.env
#
# Do NOT commit /root/.backup-r2.env — separate from app .env and image UPLOAD_S3_*.

BACKUP_R2_ACCESS_KEY_ID=
BACKUP_R2_SECRET_ACCESS_KEY=
BACKUP_R2_BUCKET=show-me-the-plan-db-backups
BACKUP_R2_ENDPOINT=https://<backup-account-id>.r2.cloudflarestorage.com
BACKUP_R2_PREFIX=db/show-me-the-plan

# Optional — match docker-compose.prod.yml if not strapi/strapi
# DATABASE_USERNAME=strapi
# DATABASE_NAME=strapi
