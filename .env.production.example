# ── Show Me The Plan — Production .env 템플릿 ───────────────────
# 실제 값은 scripts/generate-production-env.mjs 로 생성하거나
# PoC .env + 아래 REPLACE_* 항목을 수동으로 채우세요.
# 복사: cp .env.production.example .env

# ── App (Caddy + Next.js) ──────────────────────────────────────
APP_DOMAIN=showmepl.com
NEXTAUTH_URL=https://showmepl.com
NEXTAUTH_SECRET=<openssl rand -base64 32>

CORS_ORIGIN=https://showmepl.com,https://www.showmepl.com
FRONTEND_URL=https://showmepl.com

# ── Strapi secrets ─────────────────────────────────────────────
APP_KEYS=<key1>,<key2>
API_TOKEN_SALT=<random-hex>
ADMIN_JWT_SECRET=<random-hex>
TRANSFER_TOKEN_SALT=<random-hex>
JWT_SECRET=<random-hex>

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=<strong-password>

# ── External APIs ──────────────────────────────────────────────
NEIS_KEY=<from open.neis.go.kr or PoC .env>

NEIS_CACHE_ENABLED=true
NEIS_CACHE_TTL_HOURS=12
NEIS_CACHE_MAX_ENTRIES=2000

# ── Email (Brevo SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
BREVO_SMTP_USER=<id@smtp-brevo.com>
BREVO_SMTP_KEY=<xsmtpsib-...>
EMAIL_DEFAULT_FROM=<verified-sender@showmepl.com>
EMAIL_DEFAULT_NAME=Show Me The Plan

# ── Billing (PortOne V2) ─────────────────────────────────────────
BILLING_INTERNAL_SECRET=<random>
BILLING_ENCRYPTION_KEY=<32+ chars>
BILLING_CRON_SECRET=<random>
PORTONE_API_SECRET=<test-or-live>
NEXT_PUBLIC_PORTONE_STORE_ID=<store-id>
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=<channel-key>
PORTONE_WEBHOOK_SECRET=<webhook-secret>
PORTONE_WEBHOOK_SKIP_VERIFY=true

# ── Ops internal API ─────────────────────────────────────────────
OPS_INTERNAL_SECRET=<random>

# ── Web Push (VAPID) ─────────────────────────────────────────────
# cd backend && npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<public-key>
VAPID_PRIVATE_KEY=<private-key>
VAPID_SUBJECT=mailto:support@showmepl.com

# ── Upload storage ───────────────────────────────────────────────
UPLOAD_PROVIDER=local

# ── GHCR images (docker-compose.prod.yml — VPS pull only, no build) ──
# GitHub Actions "Publish Docker images" workflow on main branch.
# Example (replace YOUR_GITHUB_USER):
# SMP_FRONTEND_IMAGE=ghcr.io/YOUR_GITHUB_USER/show-me-the-plan-frontend:latest
# SMP_STRAPI_IMAGE=ghcr.io/YOUR_GITHUB_USER/show-me-the-plan-strapi:latest
#
# GitHub repo → Settings → Secrets and variables → Actions → Variables
# (used when building frontend image in CI):
#   NEXT_PUBLIC_STRAPI_URL, NEXT_PUBLIC_TURNSTILE_SITE_KEY, NEXT_PUBLIC_PORTONE_STORE_ID, NEXT_PUBLIC_PORTONE_CHANNEL_KEY
#   VAPID_PUBLIC_KEY, NEXT_PUBLIC_CONTACT_EMAIL, NEXT_PUBLIC_REPRESENTATIVE_NAME, ...

# ── Frontend build-time (NEXT_PUBLIC_*) ──────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<turnstile-site-key>
NEXT_PUBLIC_STRAPI_URL=https://showmepl.com
NEXT_PUBLIC_CONTACT_EMAIL=support@showmepl.com
NEXT_PUBLIC_OPERATOR_NAME=주식회사 쇼미플
NEXT_PUBLIC_CONTACT_PHONE=02-1234-5678
NEXT_PUBLIC_REPRESENTATIVE_NAME=홍길동
NEXT_PUBLIC_BUSINESS_REG_NO=123-45-67890
NEXT_PUBLIC_ECOMMERCE_REG_NO=제2026-서울강남-00000호
NEXT_PUBLIC_BUSINESS_ADDRESS=서울특별시 강남구 테헤란로 123, 4층
NEXT_PUBLIC_PRIVACY_OFFICER_NAME=김개인
NEXT_PUBLIC_PRIVACY_OFFICER_TITLE=대표
